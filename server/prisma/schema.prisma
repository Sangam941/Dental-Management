generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}


model AdminProfile {
  id        String   @id @db.Uuid
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admin_profiles")
}

model Department {
  id             String   @id @default(uuid()) @db.Uuid
  departmentName String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctors   Doctor[]

  @@map("departments")
}

model Doctor {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String
  phoneNumber  String?
  gender       Gender?  @default(MALE)
  departmentId String?  @db.Uuid
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  opdEntries   OpdEntry[]

  @@index([departmentId])
  @@map("doctors")
}

model OpdEntry {
  id            String   @id @default(uuid()) @db.Uuid

  entryDate     String
  entryMonth    String?
  notes         String?

  caseType      CaseType

  regNo         String?
  fullName      String
  age           Int?
  address       String?
  phoneNumber   String?
  treatment     String?
  gender        Gender? @default(MALE)

  doctorId      String?  @db.Uuid

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctor        Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  billings      Billing[]

  @@index([doctorId])
  @@map("opd_entries")
}

model Billing {
  id            String   @id @default(uuid()) @db.Uuid
  opdEntryId    String   @db.Uuid
  
  totalAmount   Decimal? @default(0)
  paymentMethod PaymentMethod? @default(CASH)
  paidAmount    Decimal? @default(0)
  dueAmount     Decimal? @default(0)
  expenseAmount Decimal? @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opdEntry      OpdEntry @relation(fields: [opdEntryId], references: [id], onDelete: Cascade)

  @@index([opdEntryId])
  @@map("billings")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CaseType {
  NEW
  OLD
}

enum PaymentMethod {
  CASH
  ONLINE
}
