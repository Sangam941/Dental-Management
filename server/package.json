{
    "name": "clinic-center-server",
    "version": "1.0.0",
    "description": "Clinic OPD Management System Backend",
    "type": "module",
    "main": "dist/src/server.js",
    "scripts": {
        "dev": "nodemon",
        "build": "prisma generate && tsc",
        "start": "prisma migrate deploy && node dist/src/server.js",
        "start:prod": "prisma migrate deploy && node dist/src/server.js",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "prisma:migrate": "prisma migrate dev",
        "prisma:deploy": "prisma migrate deploy",
        "seed": "npx prisma db seed"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "@types/pg": "^8.16.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.18.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.8",
        "@types/node": "^22.19.11",
        "nodemon": "^3.1.9",
        "prisma": "^7.4.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3"
    },
    "prisma": {
        "seed": "node --loader ts-node/esm prisma/seed.ts"
    }
}